{
  "analyzers": {
    "core": {
      "enabled": true,
      "rules": {
        "secure-parameter-default": {
          "level": "error"
        },
        "outputs-should-not-contain-secrets": {
          "level": "error"
        },
        "admin-username-should-not-be-literal": {
          "level": "error"
        },
        "no-unused-params": {
          "level": "error"
        },
        "no-unused-vars": {
          "level": "error"
        },
        "no-unused-existing-resources": {
          "level": "error"
        },
        "no-hardcoded-env-urls": {
          "level": "error"
        },
        "no-hardcoded-location": {
          "level": "warning"
        },
        "prefer-interpolation": {
          "level": "warning"
        },
        "simplify-interpolation": {
          "level": "warning"
        },
        "max-params": {
          "level": "warning"
        },
        "use-stable-vm-image": {
          "level": "warning"
        },
        "use-recent-api-versions": {
          "level": "off"
        }
      }
    }
  }
}
